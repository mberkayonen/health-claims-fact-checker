# Copy this to .env.local and fill in your values

# Anthropic API key - get from https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# No other API keys needed:
# - PubMed uses the free NCBI E-utilities API (no key required for low volume)
# - For higher volume, register at https://www.ncbi.nlm.nih.gov/account/ for a free API key
# NCBI_API_KEY=optional_ncbi_api_key
